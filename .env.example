# Environment variables for development
# Copy this file to .env.local and adjust values as needed

# Translation.io API Key (optional, only needed for explicit Translation.io sync)
# Get your key from: https://translation.io/
# NOTE: Translation.io offers free unlimited accounts for open-source projects
TRANSLATION_IO_API_KEY=

# Example: API endpoints, feature flags, etc.
# VITE_API_URL=http://localhost:8000

# Production/static deployments MUST set VITE_API_URL to an absolute API origin.
# Example:
# VITE_API_URL=https://api.customer.example
