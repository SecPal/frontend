{
  "name": "@secpal/frontend",
  "version": "0.0.1",
  "description": "React/TypeScript frontend for SecPal — operations software for German private security services.",
  "private": true,
  "type": "module",
  "author": "SecPal",
  "license": "AGPL-3.0-or-later AND LicenseRef-SecPal-Attribution",
  "repository": {
    "type": "git",
    "url": "https://github.com/SecPal/frontend.git"
  },
  "homepage": "https://github.com/SecPal/frontend#readme",
  "bugs": {
    "url": "https://github.com/SecPal/frontend/issues"
  },
  "keywords": [
    "secpal",
    "frontend",
    "react",
    "typescript",
    "vite",
    "pwa",
    "progressive-web-app",
    "offline-first",
    "push-notifications",
    "analytics"
  ],
  "scripts": {
    "dev": "vite",
    "dev:web": "cross-env VITE_APP_SURFACE=web vite --mode web",
    "dev:android": "cross-env VITE_APP_SURFACE=android-native vite --mode android",
    "dev:ios": "cross-env VITE_APP_SURFACE=ios-native vite --mode ios",
    "start": "vite",
    "build": "cross-env VITE_APP_SURFACE=web tsc && cross-env VITE_APP_SURFACE=web vite build",
    "build:web": "cross-env VITE_APP_SURFACE=web tsc && cross-env VITE_APP_SURFACE=web vite build --mode web",
    "build:android": "cross-env VITE_APP_SURFACE=android-native tsc && cross-env VITE_APP_SURFACE=android-native vite build --mode android",
    "build:ios": "cross-env VITE_APP_SURFACE=ios-native tsc && cross-env VITE_APP_SURFACE=ios-native vite build --mode ios",
    "build:analyze": "cross-env VITE_APP_SURFACE=web tsc && cross-env VITE_APP_SURFACE=web vite build --mode analyze",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --cache",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --silent=passed-only",
    "test:watch": "vitest",
    "test:run": "vitest run --bail=1",
    "test:run:all": "vitest run --reporter=verbose",
    "test:related": "vitest related --run --bail=1",
    "test:migration-boundary": "vitest run tests/auth-onboarding-migration-boundary.test.ts tests/admin-migration-boundary.test.ts tests/legacy-ui-guardrails.test.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --coverage --silent=passed-only",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ci": "cross-env CI=true playwright test",
    "test:e2e:performance": "cross-env CI=true PLAYWRIGHT_LIGHTHOUSE=1 PLAYWRIGHT_SKIP_GLOBAL_LOGIN=1 playwright test tests/e2e/performance.spec.ts --project=chromium",
    "test:e2e:performance:workspace": "node ./scripts/assert-polyscope-workspace.mjs test:e2e:performance:workspace && cross-env PLAYWRIGHT_LIGHTHOUSE=1 PLAYWRIGHT_LIVE_LIGHTHOUSE=1 PLAYWRIGHT_SKIP_GLOBAL_LOGIN=1 playwright test tests/e2e/performance.spec.ts --project=chromium",
    "test:e2e:live:onboarding": "node ./scripts/assert-polyscope-workspace.mjs test:e2e:live:onboarding && cross-env PLAYWRIGHT_LIVE_ONBOARDING=1 playwright test tests/e2e/onboarding-wizard.live.spec.ts --project=chromium",
    "test:e2e:live:passkeys": "node ./scripts/assert-polyscope-workspace.mjs test:e2e:live:passkeys && cross-env PLAYWRIGHT_LIVE_PASSKEY=1 PLAYWRIGHT_SKIP_GLOBAL_LOGIN=1 playwright test tests/e2e/passkeys.live.spec.ts --project=chromium",
    "test:e2e:live:web-push": "node ./scripts/run-live-web-push-smoke.mjs",
    "test:e2e:offline-logout": "cross-env CI=true PLAYWRIGHT_SKIP_GLOBAL_LOGIN=1 playwright test tests/e2e/offline-logout.spec.ts --project=chromium --project=mobile-chrome",
    "test:live:assetlinks": "bash ./scripts/check-live-assetlinks.sh",
    "test:live:auth-routes": "bash ./scripts/check-live-auth-route-separation.sh",
    "test:live:pwa-headers": "bash ./scripts/check-live-pwa-headers.sh",
    "test:preview:pwa-headers": "node ./scripts/check-workspace-preview-pwa-headers.mjs",
    "format": "prettier --write --cache '**/*.{md,yml,yaml,json,ts,tsx,js,jsx}'",
    "format:check": "prettier --check '**/*.{md,yml,yaml,json,ts,tsx,js,jsx}'",
    "lingui:extract": "lingui extract",
    "lingui:compile": "lingui compile --namespace es",
    "i18n:check": "node ./scripts/check-lingui-catalogs.mjs",
    "sync": "cross-env-shell \"lingui extract && lingui compile --namespace es\"",
    "sync:purge": "cross-env-shell \"lingui extract --clean && lingui compile --namespace es\"",
    "sync:local": "cross-env-shell \"lingui extract && lingui compile --namespace es\"",
    "sync:local:purge": "cross-env-shell \"lingui extract --clean && lingui compile --namespace es\"",
    "lighthouse": "npx --yes @lhci/cli@0.15.1 autorun",
    "lighthouse:ci": "npx --yes @lhci/cli@0.15.1 autorun --config=lighthouserc.cjs"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@lingui/babel-plugin-lingui-macro": "^6.5.0",
    "@lingui/cli": "^6.5.0",
    "@lingui/format-po": "^6.4.0",
    "@lingui/vite-plugin": "^6.5.0",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "jsdom-testing-mocks": "^1.16.0",
    "lighthouse": "^13.4.0",
    "markdownlint-cli": "0.49.0",
    "playwright-lighthouse": "^4.0.0",
    "prettier": "^3.9.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.2",
    "typescript": "6.0.x",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.10",
    "workbox-window": "^7.4.1"
  },
  "overrides": {
    "tmp": "^0.2.4",
    "rollup": ">=4.59.0",
    "serialize-javascript": ">=7.0.5",
    "flatted": "3.4.2",
    "picomatch@^2": "2.3.2",
    "picomatch@^4": "4.0.4",
    "brace-expansion": ">=5.0.6",
    "@isaacs/brace-expansion": ">=5.0.1",
    "minimatch": ">=10.2.4",
    "yauzl": "3.2.1",
    "glob": "^13.0.6",
    "ws@^7.0.0": "^7.5.11",
    "ws@^8.0.0": "^8.21.0",
    "esbuild": "^0.28.1",
    "@sentry/node": "^10.54.0",
    "@lingui/core": "$@lingui/core"
  },
  "engines": {
    "node": "^22.19.0 || >=24.0.0",
    "npm": ">=10.0.0"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": true
  }
}
